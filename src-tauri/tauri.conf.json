{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kairos-Pomodoro",
  "version": "1.0.0",
  "identifier": "com.kairos.pomodoro.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kairos-Pomodoro",
        "width": 1280,
        "height": 720,
        "minWidth": 320,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "msix"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "msix": {
        "identityName": "147857d0-6470-4dce-beaa-8656a7dd4f21.KairosPomodoro",
        "publisher": "CN=147857D0-6470-4DCE-BEAA-8656A7DD4F21",
        "publisherDisplayName": "Kairos-Pomodoro",
        "capabilities": ["internetClient"],
        "installMode": "user",
        "minOsBuild": "10.0.19041.0"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/shakibdshy/kairos-pomodoro/releases/latest/download/latest-{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0MEJGMEY2NTBBNTFGRApSV1Q5VVFwbEQ3OUFBZ1kvdGltNEVxU3ZWRDlmRm5WejJWeC9oeENwdkpBczgxa1pDTTE1ZVN1bwo=",
      "v1Compatible": false
    }
  }
}
